# Copy this file to .env and fill in real values. Never commit .env.

# SMTP settings for contact & waitlist form notifications.
# Works with Hostinger email hosting (support@evotrade.io) or any SMTP provider.
EMAIL_USER=support@evotrade.io
# The mailbox's real password, from Hostinger's Email panel (hPanel > Emails).
EMAIL_PASSWORD=
# Hostinger's SMTP host — confirm in hPanel > Emails > Connect Devices/Configure
# (usually smtp.hostinger.com, or smtp.yourdomain.com on some plans).
EMAIL_HOST=smtp.hostinger.com
# 465 (SSL) is Hostinger's default. Use 587 if your plan requires STARTTLS instead.
EMAIL_PORT=465
# Where form notifications should be delivered. Defaults to EMAIL_USER if unset.
EMAIL_TO=support@evotrade.io

# Admin dashboard (/admin) — tracks subscribe requests and billing status.
# Pick a strong, unique password — this is a single shared password, not per-user.
ADMIN_PASSWORD=
# Long random string used to sign the admin login session cookie.
SESSION_SECRET=

# MySQL database for subscription/billing records (hPanel > Databases > Management,
# then hPanel > Databases > Remote MySQL to allow this app to connect — "Any Host").
# A local file (SQLite) does NOT survive Hostinger redeploys, so this is required.
DB_HOST=srv1948.hstgr.io
DB_PORT=3306
DB_USER=u879338214_evotrade_admin
DB_PASSWORD=
DB_NAME=u879338214_evotradebiling

PORT=3000
NODE_ENV=production
