# Copy this file to .env and fill in real values. Never commit .env.

# SMTP settings for contact & waitlist form notifications.
# Works with Hostinger email hosting (support@evotrade.io) or any SMTP provider.
EMAIL_USER=support@evotrade.io
# The mailbox's real password, from Hostinger's Email panel (hPanel > Emails).
EMAIL_PASSWORD=
# Hostinger's SMTP host — confirm in hPanel > Emails > Connect Devices/Configure
# (usually smtp.hostinger.com, or smtp.yourdomain.com on some plans).
EMAIL_HOST=smtp.hostinger.com
# 465 (SSL) is Hostinger's default. Use 587 if your plan requires STARTTLS instead.
EMAIL_PORT=465
# Where form notifications should be delivered. Defaults to EMAIL_USER if unset.
EMAIL_TO=support@evotrade.io

PORT=3000
