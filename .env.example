# Copy this file to .env and fill in real values. Never commit .env.

# Gmail / Google Workspace SMTP for contact & waitlist form notifications.
# EMAIL_USER must be the full mailbox address that will send the email.
EMAIL_USER=support@evotrade.io
# 16-character Google App Password (NOT your regular account password).
# Generate one at https://myaccount.google.com/apppasswords
EMAIL_APP_PASSWORD=
# Where form notifications should be delivered. Defaults to EMAIL_USER if unset.
EMAIL_TO=support@evotrade.io

PORT=3000
